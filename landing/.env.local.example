# Supabase-Projekt-URL (Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co

# Supabase anon/public Key (Settings -> API -> Project API keys -> anon public)
# Dieser Key ist bewusst öffentlich (client-seitig) und durch Row Level Security abgesichert.
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-public-key
