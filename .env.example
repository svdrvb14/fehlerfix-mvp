ANTHROPIC_API_KEY=dein-key-hier
# Modell-Auswahl (optional, default = claude-sonnet-4-6):
#   claude-sonnet-4-6   ← schnell, gut, günstig (empfohlen)
#   claude-opus-4-8     ← Top-Qualität, ~5x teurer als Sonnet
# CLAUDE_MODEL=claude-sonnet-4-6
PORT=3000

# ─── Supabase (Datenbank + Auth) ───
SUPABASE_URL=https://dein-projekt.supabase.co
SUPABASE_ANON_KEY=dein-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key-GEHEIM
# Secret für Login-Session-Cookies (mit `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"` generieren)
SESSION_SECRET=langer-zufaelliger-string
